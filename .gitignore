# Runtime data — local state, uploaded files, generated images.
# Never commit; it contains API keys, conversation history, and personal info.
/pc-data/
/dist/pc-data/

# Build artefacts — regenerated by `bun run build` / `bun run compile` / `tauri build`.
# Includes the 113 MB Bun-compiled sidecar exe and the 36 MB NSIS installer,
# both of which exceed GitHub's per-file size sweet spot and are pure build outputs.
/dist/
/web-ui/build/
/web-ui/.react-router/
/web-ui/node_modules/
/web-ui/src-tauri/binaries/*.exe
/web-ui/src-tauri/gen/
/web-ui/src-tauri/target/

# External Cargo build dir (we point CARGO_TARGET_DIR here to avoid the project's
# non-ASCII path; in case anyone keeps their build inside the project tree).
/target/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.iml

# Bun / Node
node_modules/

# Logs
*.log
